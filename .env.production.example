# AIOps Monitor production environment example
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE=aiops_monitor
MYSQL_USER=aiops
MYSQL_PASSWORD=change-aiops-db-password
REDIS_PASSWORD=change-redis-password
JWT_SECRET=replace-with-at-least-64-random-characters
JWT_EXPIRATION_MS=86400000
REGISTRATION_ENABLED=false
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe-2026!
PASSWORD_MIN_LENGTH=10
OLLAMA_MODEL=qwen3:0.6b
VITE_API_BASE_URL=https://aiops.example.com
VITE_WS_BASE_URL=https://aiops.example.com
VITE_AGENT_BASE_URL=https://aiops.example.com/agent
AGENT_SIGNING_KEY=replace-agent-signing-key
PASSWORD_RESET_MAIL_ENABLED=true
PASSWORD_RESET_FRONTEND_URL=https://aiops.example.com/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=change-smtp-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
PASSWORD_RESET_MAIL_FROM=no-reply@example.com
NOTIFICATION_MAIL_ENABLED=true
NOTIFICATION_MAIL_FROM=no-reply@example.com
